<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>Sistemas Masivos Integrados — Caracas</name>
  <description>Metrocable MC1 y MC2, Cabletrén Petare, BusCaracas (Línea 7 Metro). Todos integrados al sistema de la C.A. Metro de Caracas.</description>

  <!-- Metrocable Violeta #790D9B -->
  <Style id="cable_line"><LineStyle><color>FF9B0D79</color><width>4</width></LineStyle></Style>
  <Style id="cable_stop"><IconStyle><color>FF9B0D79</color><scale>0.7</scale><Icon><href>http://maps.google.com/mapfiles/kml/shapes/airports.png</href></Icon></IconStyle><LabelStyle><scale>0.65</scale></LabelStyle></Style>

  <!-- Cabletrén Verde Lima #32CD32 -->
  <Style id="ct_line"><LineStyle><color>FF32CD32</color><width>4</width></LineStyle></Style>
  <Style id="ct_stop"><IconStyle><color>FF32CD32</color><scale>0.65</scale><Icon><href>http://maps.google.com/mapfiles/kml/shapes/airports.png</href></Icon></IconStyle><LabelStyle><scale>0.6</scale></LabelStyle></Style>

  <!-- BusCaracas L7 Rojo #CC2222 -->
  <Style id="brt_line"><LineStyle><color>FF2222CC</color><width>4</width></LineStyle></Style>
  <Style id="brt_stop"><IconStyle><color>FF2222CC</color><scale>0.7</scale><Icon><href>http://maps.google.com/mapfiles/kml/shapes/bus.png</href></Icon></IconStyle><LabelStyle><scale>0.6</scale></LabelStyle></Style>

  <!-- ─────────────────────────────────────────────
