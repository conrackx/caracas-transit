        -66.865000,10.492500,0
      </coordinates></LineString>
    </Placemark>
    <Placemark><name>P08 | Origen: Propatria / Casalta</name><styleUrl>#priv_term</styleUrl><Description>Coord [OSM] tomada de estación Propatria L1 · Wikidata Q6087917</Description><Point><coordinates>-66.955959,10.504739,0</coordinates></Point></Placemark>
    <Placemark><name>P08 | Parada: Metrocenter / Av. San Martín</name><styleUrl>#priv_term</styleUrl><Point><coordinates>-66.925000,10.497000,0</coordinates></Point></Placemark>
    <Placemark><name>P08 | Destino: Chacaíto</name><styleUrl>#priv_term</styleUrl><Point><coordinates>-66.865000,10.492500,0</coordinates></Point></Placemark>
