    <visibility>0</visibility>
    <description>[SOLO TERMINALES] Av. Baralt → El Calvario → El Paraíso → Redoma La India. Fuente: TalCual Digital feb. 2023.</description>
    <Placemark><name>P11 | Origen: Av. Baralt</name><styleUrl>#priv_term</styleUrl><Point><coordinates>-66.896000,10.492000,0</coordinates></Point></Placemark>
