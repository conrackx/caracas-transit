    <visibility>0</visibility>
    <description>[SOLO TERMINALES] Redoma La India → Montalbán → Antímano → Metro Zoológico (L2). Fuente: TalCual Digital feb. 2023.</description>
    <Placemark><name>P07 | Origen: Redoma La India</name><styleUrl>#priv_term</styleUrl><Point><coordinates>-66.925000,10.497000,0</coordinates></Point></Placemark>
